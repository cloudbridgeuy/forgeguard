# Generated by Cargo
# will have compiled files and executables
/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# Don't store archived files
/archive/

.DS_Store

# Claude Code settings (keep context docs and commands only)
.claude/*
!.claude/context/
!.claude/commands/

# Build logs
**/xtask-lint.log

# Local development
.local/

# Control plane org configs (contain tokens and AWS resource IDs)
**/orgs.json

# Generated signing keys (Ed25519 PEM files)
**/keys/*.pem

# Control plane infra
infra/control-plane/node_modules/
infra/control-plane/cdk.out/

# Playwright MCP screenshots
.playwright-mcp/

# Python
__pycache__/

# Bacon
.bacon-locations
