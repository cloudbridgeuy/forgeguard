          {"method": "DELETE", "path": "/api/todos/:id", "action": "todo:item:delete", "resource_param": "id"}
        ],
        "public_routes": [
          {"method": "GET", "path": "/health", "auth_mode": "anonymous"}
        ],
        "features": {}
      }
    },
    "org-globex": {
